pipeline {

    agent any

    stages {

        stage('Build') {

            steps {

                sh '''
                apt-get update
                apt-get install -y maven
                mvn clean install
                '''

            }

        }

        stage('Verify Build') {

            steps {

                sh 'ls target'

            }

        }

        stage('Deploy') {

            steps {

                echo 'Deployment handled using Docker Compose separately'

            }

        }

    }

}