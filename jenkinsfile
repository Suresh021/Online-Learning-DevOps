pipeline {

    agent any

    stages {

        stage('Build') {

            steps {

                sh '''
                docker run --rm \
                -v $PWD:/app \
                -w /app \
                maven:3.9-eclipse-temurin-21 \
                mvn clean install
                '''

            }

        }

        stage('Docker Build') {

            steps {

                sh 'docker build -t onlinelearningapp .'

            }

        }

        stage('Deploy') {

            steps {

                sh 'docker-compose up -d'

            }

        }

    }

}