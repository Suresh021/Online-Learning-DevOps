pipeline {

    agent {
        docker {
            image 'maven:3.9-eclipse-temurin-21'
        }
    }

    stages {

        stage('Build') {

            steps {

                sh 'mvn clean install'

            }

        }

        stage('Verify Build') {

            steps {

                sh 'ls target'

            }

        }

        stage('Deploy') {

            steps {

                echo 'Deployment handled using Docker Compose'

            }

        }

    }

}